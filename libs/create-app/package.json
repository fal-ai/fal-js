{
  "name": "@fal-ai/create-app",
  "version": "0.2.0-alpha.0",
  "description": "The fal app generator.",
  "type": "module",
  "license": "MIT",
  "main": "src/index.js",
  "bin": {
    "create-fal-app": "./bin/run.js"
  },
  "files": [
    "bin"
  ],
  "keywords": [
    "fal",
    "next",
    "nextjs",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fal-ai/fal-js.git",
    "directory": "libs/create-app"
  },
  "dependencies": {
    "@astrojs/cli-kit": "^0.4.1",
    "@inquirer/prompts": "^3.3.0",
    "@inquirer/select": "^1.3.1",
    "@oclif/core": "^4.0.17",
    "@oclif/plugin-help": "^6.2.8",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "execa": "^8.0.1",
    "open": "^10.0.3",
    "ora": "^8.0.1"
  },
  "oclif": {
    "bin": "create-fal-app",
    "commands": {
      "strategy": "single",
      "target": "./src/index.js"
    },
    "dirname": "create-fal-app",
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.44",
    "ts-node": "^10.9.2"
  }
}
